# -----------------------------
# Python cache & compiled files
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------
# Virtual environments
# -----------------------------
.venv/
venv/
env/
ENV/

# -----------------------------
# Environment variables
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# Logs & temp files
# -----------------------------
*.log
*.out
*.err
debug*.log
tmp/
temp/

# -----------------------------
# IDE / Editor files
# -----------------------------
.vscode/
.idea/
.cursor/
*.suo
*.ntvs*
*.njsproj
*.sln

# -----------------------------
# OS files
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Build / packaging
# -----------------------------
build/
dist/
*.egg-info/
.eggs/
*.whl

# -----------------------------
# Python tools
# -----------------------------
.mypy_cache/
.pytest_cache/
.ruff_cache/
coverage/
htmlcov/

# -----------------------------
# Dependency locks (optional)
# -----------------------------
# Uncomment if you don’t want to track lock files
# uv.lock

# -----------------------------
# Data / model files (important for ML projects)
# -----------------------------
data/
models/
checkpoints/
*.ckpt
*.pt
*.pth

# -----------------------------
# Notebook checkpoints
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Secrets / API keys
# -----------------------------
